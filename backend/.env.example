# =====================================
# ChatSphere Environment Configuration
# =====================================

# Server
NODE_ENV=production
PORT=5000

# Frontend URL (Render Frontend URL)
FRONTEND_URL=https://your-frontend.onrender.com

# PostgreSQL Database (Render PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database

# JWT
JWT_SECRET=replace_with_a_long_random_secret_32_chars_minimum
JWT_EXPIRES_IN=7d

# Admin Bootstrap Account
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@chatsphere.com
ADMIN_PASSWORD=change_this_password_strong

# Cloudinary (Optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# File Upload
MAX_FILE_SIZE=10485760

# Socket.IO
SOCKET_CORS_ORIGIN=https://your-frontend.onrender.com
